/** Modern Light Theme - Material Design 3
 * 适用于 Qt 6.x / Qt 5.x
 * 浅色主题，紫色主色调
 *
 * 注意：本文件中 rgba() 仅用于 hover/selection 等交互状态，
 * 静态背景色一律使用纯色 #hex，符合 QSS 纯色优先原则。
 * rgba() 在全局样式表中是可接受的（只加载一次，不频繁更新），
 * 但在运行时动态 setStyleSheet() 中应避免使用。
 */

/* ==================== 全局样式 ==================== */
* {
    font-family: "Segoe UI", "Microsoft YaHei", "PingFang SC", sans-serif;
    font-size: 10pt;
    outline: none;
}

/* ==================== 主窗口 ==================== */
QMainWindow, QDialog {
    background-color: #FAFAFA;
    color: #212121;
}

/* ==================== 按钮 ==================== */
QPushButton {
    background-color: #6200EE;
    color: #FFFFFF;
    border: none;
    border-radius: 20px;
    padding: 10px 24px;
    min-width: 64px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #7C4DFF;
}

QPushButton:pressed {
    background-color: #3700B3;
}

QPushButton:disabled {
    background-color: #E0E0E0;
    color: #9E9E9E;
}

QPushButton:default {
    background-color: #03DAC6;
    color: #000000;
}

QPushButton:default:hover {
    background-color: #66FFF9;
}

QPushButton:default:pressed {
    background-color: #00A896;
}

/* 文字按钮 */
QPushButton[flat="true"] {
    background-color: transparent;
    color: #6200EE;
    padding: 8px 16px;
}

QPushButton[flat="true"]:hover {
    background-color: rgba(98, 0, 238, 0.04);
}

QPushButton[flat="true"]:pressed {
    background-color: rgba(98, 0, 238, 0.12);
}

/* 描边按钮 */
QPushButton[outlined="true"] {
    background-color: transparent;
    color: #6200EE;
    border: 1px solid #6200EE;
    padding: 9px 23px;
}

QPushButton[outlined="true"]:hover {
    background-color: rgba(98, 0, 238, 0.04);
}

QPushButton[outlined="true"]:pressed {
    background-color: rgba(98, 0, 238, 0.12);
}

/* ==================== 输入框 ==================== */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    padding: 12px 16px;
    selection-background-color: #6200EE;
    selection-color: #FFFFFF;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 2px solid #6200EE;
    padding: 11px 15px;
}

QLineEdit:disabled, QTextEdit:disabled, QPlainTextEdit:disabled {
    background-color: #F5F5F5;
    color: #9E9E9E;
    border-color: #E0E0E0;
}

QLineEdit::placeholder {
    color: #9E9E9E;
}

/* ==================== 组合框 ==================== */
QComboBox {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    padding: 12px 16px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: #BDBDBD;
}

QComboBox:focus {
    border: 2px solid #6200EE;
    padding: 11px 15px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 40px;
    border-left: 1px solid #E0E0E0;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #616161;
    width: 0;
    height: 0;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    selection-background-color: #E8E0F0;
    selection-color: #6200EE;
    outline: none;
}

QComboBox QAbstractItemView::item {
    padding: 12px 16px;
    min-height: 24px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #F5F5F5;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #E8E0F0;
}

/* ==================== 复选框和单选框 ==================== */
QCheckBox, QRadioButton {
    color: #212121;
    spacing: 12px;
}

QCheckBox::indicator, QRadioButton::indicator {
    width: 20px;
    height: 20px;
}

QCheckBox::indicator:unchecked {
    border: 2px solid #757575;
    border-radius: 2px;
    background-color: transparent;
}

QCheckBox::indicator:unchecked:hover {
    border-color: #6200EE;
}

QCheckBox::indicator:checked {
    border: 2px solid #6200EE;
    border-radius: 2px;
    background-color: #6200EE;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxNCIgaGVpZ2h0PSIxNCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IiNGRkYiIHN0cm9rZS13aWR0aD0iMyI+PHBvbHlsaW5lIHBvaW50cz0iMjAgNiA5IDE3IDQgMTIiPjwvcG9seWxpbmU+PC9zdmc+);
}

QCheckBox::indicator:indeterminate {
    border: 2px solid #6200EE;
    border-radius: 2px;
    background-color: #6200EE;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxNCIgaGVpZ2h0PSIxNCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IiNGRkYiIHN0cm9rZS13aWR0aD0iMyI+PGxpbmUgeDE9IjUiIHkxPSIxMiIgeDI9IjE5IiB5Mj0iMTIiPjwvbGluZT48L3N2Zz4=);
}

QRadioButton::indicator:unchecked {
    border: 2px solid #757575;
    border-radius: 10px;
    background-color: transparent;
}

QRadioButton::indicator:unchecked:hover {
    border-color: #6200EE;
}

QRadioButton::indicator:checked {
    border: 2px solid #6200EE;
    border-radius: 10px;
    background-color: #6200EE;
}

QCheckBox::indicator:disabled, QRadioButton::indicator:disabled {
    border-color: #BDBDBD;
}

QCheckBox::indicator:checked:disabled, QRadioButton::indicator:checked:disabled {
    background-color: #E0E0E0;
    border-color: #E0E0E0;
}

/* ==================== 滑块 ==================== */
QSlider::groove:horizontal {
    height: 4px;
    background: #E0E0E0;
    border-radius: 2px;
}

QSlider::sub-page:horizontal {
    background: #6200EE;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    width: 20px;
    height: 20px;
    margin: -8px 0;
    background: #6200EE;
    border: 2px solid #FFFFFF;
    border-radius: 10px;
}

QSlider::handle:horizontal:hover {
    background: #7C4DFF;
    width: 24px;
    height: 24px;
    margin: -10px 0;
}

QSlider::handle:horizontal:pressed {
    background: #3700B3;
}

/* ==================== 进度条 ==================== */
QProgressBar {
    background-color: #E0E0E0;
    border-radius: 4px;
    text-align: center;
    color: #212121;
    height: 8px;
}

QProgressBar::chunk {
    background-color: #6200EE;
    border-radius: 4px;
}

QProgressBar:indeterminate::chunk {
    background-color: #6200EE;
    width: 40px;
    margin-right: 4px;
}

/* ==================== 滚动条 ==================== */
QScrollBar:vertical {
    background-color: transparent;
    width: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #BDBDBD;
    border-radius: 6px;
    min-height: 40px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #9E9E9E;
}

QScrollBar::handle:vertical:pressed {
    background-color: #757575;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background-color: transparent;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 12px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background-color: #BDBDBD;
    border-radius: 6px;
    min-width: 40px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #9E9E9E;
}

/* ==================== 标签页 ==================== */
QTabWidget::pane {
    border: 1px solid #E0E0E0;
    background-color: #FFFFFF;
    border-radius: 0 4px 4px 4px;
    top: -1px;
}

QTabBar::tab {
    background-color: transparent;
    color: #757575;
    padding: 12px 24px;
    border: none;
    border-bottom: 2px solid transparent;
}

QTabBar::tab:hover {
    color: #424242;
    background-color: rgba(0, 0, 0, 0.04);
}

QTabBar::tab:selected {
    background-color: #FFFFFF;
    color: #6200EE;
    border-bottom: 2px solid #6200EE;
}

/* ==================== 表格 ==================== */
QTableWidget, QTableView {
    background-color: #FFFFFF;
    color: #212121;
    gridline-color: #EEEEEE;
    border: none;
    selection-background-color: #E8E0F0;
    selection-color: #6200EE;
    alternate-background-color: #FAFAFA;
}

QTableWidget::item, QTableView::item {
    padding: 12px;
    border: none;
}

QTableWidget::item:selected, QTableView::item:selected {
    background-color: #E8E0F0;
}

QTableWidget::item:hover, QTableView::item:hover {
    background-color: #F5F5F5;
}

QHeaderView::section {
    background-color: #FAFAFA;
    color: #424242;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #E0E0E0;
    font-weight: 500;
}

QHeaderView::section:hover {
    background-color: #EEEEEE;
}

/* ==================== 分组框 ==================== */
QGroupBox {
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    margin-top: 16px;
    padding-top: 20px;
    font-weight: 500;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 16px;
    padding: 0 8px;
    color: #6200EE;
}

/* ==================== 菜单 ==================== */
QMenuBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E0E0E0;
}

QMenuBar::item {
    background-color: transparent;
    padding: 10px 16px;
    color: #424242;
}

QMenuBar::item:selected {
    background-color: #E8E0F0;
    color: #6200EE;
}

QMenu {
    background-color: #FFFFFF;
    border: 1px solid #E0E0E0;
    padding: 8px 0;
    border-radius: 4px;
}

QMenu::item {
    padding: 10px 24px;
    color: #424242;
}

QMenu::item:selected {
    background-color: #E8E0F0;
    color: #6200EE;
}

QMenu::item:disabled {
    color: #BDBDBD;
}

QMenu::separator {
    height: 1px;
    background-color: #E0E0E0;
    margin: 8px 16px;
}

/* ==================== 工具栏 ==================== */
QToolBar {
    background-color: #FFFFFF;
    border: none;
    padding: 8px;
    spacing: 4px;
}

QToolBar::separator {
    width: 1px;
    background-color: #E0E0E0;
    margin: 4px 8px;
}

QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 8px;
    color: #424242;
}

QToolButton:hover {
    background-color: rgba(0, 0, 0, 0.04);
}

QToolButton:pressed {
    background-color: rgba(0, 0, 0, 0.08);
}

QToolButton:checked {
    background-color: #E8E0F0;
    color: #6200EE;
}

/* ==================== 停靠窗口 ==================== */
QDockWidget {
    titlebar-close-icon: url(none);
    titlebar-normal-icon: url(none);
}

QDockWidget::title {
    background-color: #FAFAFA;
    padding: 12px;
    border-bottom: 1px solid #E0E0E0;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background-color: transparent;
    border-radius: 4px;
    padding: 4px;
    icon-size: 16px;
}

QDockWidget::close-button:hover,
QDockWidget::float-button:hover {
    background-color: rgba(0, 0, 0, 0.04);
}

/* ==================== 列表视图 ==================== */
QListView, QListWidget {
    background-color: #FFFFFF;
    color: #212121;
    border: none;
    outline: none;
    selection-background-color: #E8E0F0;
    selection-color: #6200EE;
}

QListView::item, QListWidget::item {
    padding: 12px 16px;
    border-radius: 4px;
    margin: 2px 4px;
}

QListView::item:hover, QListWidget::item:hover {
    background-color: #F5F5F5;
}

QListView::item:selected, QListWidget::item:selected {
    background-color: #E8E0F0;
}

/* ==================== 树形视图 ==================== */
QTreeView, QTreeWidget {
    background-color: #FFFFFF;
    color: #212121;
    border: none;
    outline: none;
    selection-background-color: #E8E0F0;
    selection-color: #6200EE;
}

QTreeView::item, QTreeWidget::item {
    padding: 8px 12px;
}

QTreeView::item:hover, QTreeWidget::item:hover {
    background-color: #F5F5F5;
}

QTreeView::item:selected, QTreeWidget::item:selected {
    background-color: #E8E0F0;
}

/* ==================== 分割器 ==================== */
QSplitter::handle {
    background-color: #E0E0E0;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}

QSplitter::handle:hover {
    background-color: #6200EE;
}

/* ==================== 状态栏 ==================== */
QStatusBar {
    background-color: #FFFFFF;
    color: #757575;
    border-top: 1px solid #E0E0E0;
}

QStatusBar::item {
    border: none;
}

/* ==================== 提示框 ==================== */
QToolTip {
    background-color: #424242;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 8px 12px;
}

/* ==================== 旋转框 ==================== */
QSpinBox, QDoubleSpinBox {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    padding: 12px;
    padding-right: 24px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 2px solid #6200EE;
    padding: 11px;
    padding-right: 23px;
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 24px;
    border-left: 1px solid #E0E0E0;
    border-top-right-radius: 4px;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 24px;
    border-left: 1px solid #E0E0E0;
    border-bottom-right-radius: 4px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: rgba(0, 0, 0, 0.04);
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #616161;
    width: 0;
    height: 0;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #616161;
    width: 0;
    height: 0;
}

/* ==================== 日期时间选择器 ==================== */
QDateTimeEdit {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    padding: 12px;
}

QDateTimeEdit:focus {
    border: 2px solid #6200EE;
    padding: 11px;
}

QCalendarWidget {
    background-color: #FFFFFF;
}

QCalendarWidget QTableView {
    background-color: #FFFFFF;
    selection-background-color: #6200EE;
    selection-color: #FFFFFF;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #FAFAFA;
}

QCalendarWidget QToolButton {
    color: #424242;
    background-color: transparent;
    padding: 8px;
}

QCalendarWidget QToolButton:hover {
    background-color: rgba(0, 0, 0, 0.04);
}

QCalendarWidget QSpinBox {
    background-color: transparent;
    border: none;
    color: #424242;
}

/* ==================== 字体选择框 ==================== */
QFontComboBox {
    background-color: #FFFFFF;
    color: #212121;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    padding: 12px 16px;
}

QFontComboBox:focus {
    border: 2px solid #6200EE;
    padding: 11px 15px;
}
